@model QuickLoan.Models.Loan

@{
    ViewData["Title"] = "Edit Loan";
}

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h3>Edit Loan</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Hidden ID -->
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="BorrowerName" class="form-label"></label>
                    <input asp-for="BorrowerName" class="form-control" />
                    <span asp-validation-for="BorrowerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LenderName" class="form-label"></label>
                    <input asp-for="LenderName" class="form-control" />
                    <span asp-validation-for="LenderName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Amount" class="form-label"></label>
                    <input asp-for="Amount" class="form-control" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="IsSettled" />
                    <label class="form-check-label" asp-for="IsSettled"></label>
                </div>

                <button type="submit" class="btn btn-warning">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>

            </form>

        </div>

    </div>

</div>