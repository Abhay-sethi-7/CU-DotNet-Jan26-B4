@model IEnumerable<QuickLoan.Models.Loan>

@{
    ViewData["Title"] = "Loan List";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h2>Loan List</h2>
        <a asp-action="Create" class="btn btn-primary">Create New Loan</a>
    </div>

    <table class="table table-striped table-bordered table-hover shadow table-responsive text-center ">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Id)</th>
                <th>@Html.DisplayNameFor(model => model.BorrowerName)</th>
                <th>@Html.DisplayNameFor(model => model.LenderName)</th>
                <th>@Html.DisplayNameFor(model => model.Amount)</th>
                <th>@Html.DisplayNameFor(model => model.IsSettled)</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Id)</td>
                    <td>@Html.DisplayFor(modelItem => item.BorrowerName)</td>
                    <td>@Html.DisplayFor(modelItem => item.LenderName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Amount)</td>
                    <td>@Html.DisplayFor(modelItem => item.IsSettled)</td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info btn-sm">Edit</a>

                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-success btn-sm">Details</a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>