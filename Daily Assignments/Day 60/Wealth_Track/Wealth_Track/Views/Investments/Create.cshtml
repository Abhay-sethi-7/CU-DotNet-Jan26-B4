@using Wealth_Track.ViewModel
@model InvestmentCreateViewModel

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label asp-for="TickerSymbol"></label>
        <input asp-for="TickerSymbol" maxlength="10" />
        <span asp-validation-for="TickerSymbol" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="AssetName"></label>
        <input asp-for="AssetName" />
        <span asp-validation-for="AssetName" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" step="1" min="1" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="TotalValue"></label>
        <input asp-for="TotalValue" readonly />
    </div>

    <button type="submit">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const priceEl = document.querySelector('[name="Price"]');
            const qtyEl = document.querySelector('[name="Quantity"]');
            const totalEl = document.querySelector('[name="TotalValue"]');

            function formatCurrency(value) {
               
                return '$' + (value || 0).toFixed(2);
            }

            function updateTotal() {
                const price = parseFloat(priceEl?.value) || 0;
                const qty = parseInt(qtyEl?.value) || 0;
                const total = price * qty;
                if (totalEl) totalEl.value = formatCurrency(total);
            }

            priceEl?.addEventListener('input', updateTotal);
            qtyEl?.addEventListener('input', updateTotal);

           
            updateTotal();
        })();
    </script>
}