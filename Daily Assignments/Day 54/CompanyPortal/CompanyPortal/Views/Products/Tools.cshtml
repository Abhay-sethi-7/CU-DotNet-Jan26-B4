
@{
    ViewData["Title"] = "Tools";
}

<div class="container mt-4">

    <h2 class="mb-4">Our Software Tools</h2>

    <!-- Intro Alert -->
    <div class="alert alert-warning">
        We provide powerful tools to help developers and businesses improve productivity and workflow.
    </div>

    <!-- Tools Cards -->
    <div class="row">

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Code Editor Tool</h5>
                    <p class="card-text">
                        A smart coding tool that helps developers write, edit, and manage code efficiently.
                    </p>
                    <button class="btn btn-primary">Explore Tool</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Project Management Tool</h5>
                    <p class="card-text">
                        Organize tasks, track progress, and collaborate with team members easily.
                    </p>
                    <button class="btn btn-success">Explore Tool</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Testing & Debug Tool</h5>
                    <p class="card-text">
                        Identify bugs, test applications, and improve software performance quickly.
                    </p>
                    <button class="btn btn-danger">Explore Tool</button>
                </div>
            </div>
        </div>

    </div>

    <!-- Accordion Section -->
    <div class="mt-5">
        <h3>Why Use Our Tools?</h3>

        <div class="accordion" id="toolsAccordion">

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#one">
                        User Friendly
                    </button>
                </h2>
                <div id="one" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        Our tools are designed with simple interfaces that make them easy to use.
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#two">
                        High Performance
                    </button>
                </h2>
                <div id="two" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        Built with modern technology to deliver fast and reliable performance.
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>