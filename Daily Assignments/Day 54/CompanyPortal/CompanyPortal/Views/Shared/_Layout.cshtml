<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CompanyPortal</title>
    <link rel="icon" type="image/x-icon" href="~/Logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CompanyPortal.styles.css" asp-append-version="true" />
    <script>
        function showToast() {

            var toastElement = document.getElementById('myToast');
            var toast = new bootstrap.Toast(toastElement, { delay: 3000 });

            toast.show();
        }
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">


                <a class="navbar-brand d-flex align-items-center" href="/">
                    <img src="~/Logo.png" alt="Logo" width="40" height="40" class="me-2">
                    CompanyPortal
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/About">About</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Services</a>

                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Services/Index">All Services</a></li>
                                <li><a class="dropdown-item" href="/Services/Consulting">Consulting</a></li>
                                <li><a class="dropdown-item" href="/Services/Training">Training</a></li>
                            </ul>

                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Products</a>

                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Products/Index">All Products</a></li>
                                <li><a class="dropdown-item" href="/Products/Software">Software</a></li>
                                <li><a class="dropdown-item" href="/Products/Tools">Tools</a></li>
                            </ul>

                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Contact/Index">Contact</a>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CompanyPortal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
