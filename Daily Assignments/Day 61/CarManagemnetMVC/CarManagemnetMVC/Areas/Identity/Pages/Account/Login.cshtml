@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <!-- Card -->
            <div class="card shadow-lg p-4">

                <!-- Logo / Title -->
                <div class="text-center mb-3">
                    <h2 class="text-primary"> Car Management System</h2>
                    <p class="text-muted">Login to continue</p>
                </div>

                <form id="account" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Email -->
                    <div class="form-group mb-3">
                        <label>Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="Enter email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-group mb-3">
                        <label>Password</label>
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Enter password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- Remember Me -->
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label">Remember Me</label>
                    </div>

                    <!-- Login Button -->
                    <button type="submit" class="btn btn-primary w-100">Login</button>

                    <!-- Links -->
                    <div class="text-center mt-3">
                        <a asp-page="./Register">Create Account</a> |
                        <a asp-page="./ForgotPassword">Forgot Password?</a>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}