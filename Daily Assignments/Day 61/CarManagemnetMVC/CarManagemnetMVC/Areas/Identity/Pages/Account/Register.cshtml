@page
@model RegisterModel

@{
    ViewData["Title"] = "Register";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <!-- Card -->
            <div class="card shadow-lg p-4">

                <!-- Title -->
                <div class="text-center mb-3">
                    <h2 class="text-success">Create Account</h2>
                    <p class="text-muted">Join Car Management System</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Email -->
                    <div class="form-group mb-3">
                        <label>Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="Enter email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-group mb-3">
                        <label>Password</label>
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Enter password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="form-group mb-3">
                        <label>Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- Register Button -->
                    <button type="submit" class="btn btn-success w-100">Register</button>

                    <!-- Links -->
                    <div class="text-center mt-3">
                        <a asp-page="./Login">Already have an account? Login</a>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}