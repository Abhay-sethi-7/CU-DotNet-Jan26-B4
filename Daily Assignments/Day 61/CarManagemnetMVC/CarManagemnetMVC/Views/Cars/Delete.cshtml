@model CarManagemnetMVC.Models.Car

@{
    ViewData["Title"] = "Delete Car";
}

<div class="container mt-5">

    <!-- Title -->
    <div class="text-center mb-4">
        <h2 class="text-danger">Delete Car</h2>
        <p class="text-muted">Are you sure you want to delete this car?</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">

            <!-- Card -->
            <div class="card shadow p-4">

                <!-- Car Details -->
                <h5 class="mb-3 text-center">Car Details</h5>
                <hr />

                <dl class="row">
                    <dt class="col-sm-4">Brand</dt>
                    <dd class="col-sm-8">@Model.Brand</dd>

                    <dt class="col-sm-4">Model</dt>
                    <dd class="col-sm-8">@Model.Model</dd>

                    <dt class="col-sm-4">Year</dt>
                    <dd class="col-sm-8">@Model.Year</dd>

                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8">₹ @Model.Price</dd>
                </dl>

                <!-- Buttons -->
                <form asp-action="Delete" class="mt-3">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <input type="submit" value="Delete" class="btn btn-danger" />
                    </div>
                </form>

            </div>

        </div>
    </div>
</div>