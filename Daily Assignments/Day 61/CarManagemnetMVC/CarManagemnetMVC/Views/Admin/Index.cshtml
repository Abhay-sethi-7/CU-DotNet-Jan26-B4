@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "Admin Panel";
}

<div class="container mt-5">

    <h2 class="text-danger mb-4">Admin Dashboard</h2>

    <table class="table table-bordered text-center">
        <thead class="table-dark">
            <tr>
                <th>Email</th>
                <th>Assign Role</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        <a asp-action="AssignRole" asp-route-userId="@user.Id" asp-route-role="User" class="btn btn-secondary btn-sm">User</a>
                        <a asp-action="AssignRole" asp-route-userId="@user.Id" asp-route-role="Customer" class="btn btn-success btn-sm">Customer</a>
                        <a asp-action="AssignRole" asp-route-userId="@user.Id" asp-route-role="Admin" class="btn btn-danger btn-sm">Admin</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>