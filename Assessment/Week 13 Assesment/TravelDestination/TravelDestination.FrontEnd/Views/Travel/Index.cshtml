@model IEnumerable<TravelDestination.FrontEnd.Models.Destination>

@{
    ViewData["Title"] = "Destinations";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<div class="container py-4">

    <!-- Header -->
    <div class="p-4 mb-4 text-white rounded-4 shadow"
         style="background: linear-gradient(135deg, #4e73df, #1cc88a);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Travel Destinations</h2>
                <p class="mb-0">Explore, manage and relive your journeys</p>
            </div>

            <a asp-action="Create" class="btn btn-light fw-semibold shadow-sm">
                <i class="bi bi-plus-circle"></i> Add Destination
            </a>
        </div>
    </div>

    <!-- Destinations Grid -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 rounded-4 destination-card">

                    <!-- Card Body -->
                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold text-primary">
                            <i class="bi bi-geo-alt-fill"></i> @item.CityName
                        </h5>

                        <h6 class="text-muted mb-2">@item.Country</h6>

                        <p class="card-text small text-secondary">
                            @item.Description
                        </p>

                        <!-- Rating -->
                        <div class="mb-2">
                            <span class="badge bg-warning text-dark px-3 py-2">
                                ⭐ @item.Rating / 5
                            </span>
                        </div>

                        <!-- Date -->
                        <p class="text-muted small mb-3">
                            <i class="bi bi-calendar-event"></i>
                            Last Visited: @item.LastVisited.ToShortDateString()
                        </p>

                        <!-- Actions -->
                        <div class="mt-auto d-flex justify-content-between">

                            <a asp-action="Details"
                               asp-route-id="@item.DestinationID"
                               class="btn btn-outline-info btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.DestinationID"
                               class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.DestinationID"
                               class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </a>

                        </div>

                    </div>
                </div>
            </div>
        }

    </div>
</div>

