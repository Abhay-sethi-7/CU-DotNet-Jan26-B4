@model TravelDestination.FrontEnd.Models.Destination

@{
    ViewData["Title"] = "Destination Details";
}

<h2 class="mb-4">Destination Details</h2>

<div class="card">
    <div class="card-header bg-dark text-white">
        <h4>@Model.CityName, @Model.Country</h4>
    </div>

    <div class="card-body">
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Rating:</strong> @Model.Rating</p>
        <p><strong>Last Visited:</strong> @Model.LastVisited.ToShortDateString()</p>
    </div>

    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.DestinationID" class="btn btn-warning">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.DestinationID" class="btn btn-danger">Delete</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>