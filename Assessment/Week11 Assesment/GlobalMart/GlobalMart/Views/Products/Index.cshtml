@{
    ViewData["Title"] = "Products";
    var promoCode = Context.Request.Query["promoCode"].ToString();
    var promoCodes = ViewBag.PromoCodes as IEnumerable<string> ?? new List<string>();
}



<div class="container py-5">
    <h2 class="text-center mb-4">Featured Product</h2>

    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">

                    <h3 class="card-title">Winter Jacket</h3>

                    <div class="my-3">
                        <span class="text-muted text-decoration-line-through me-2">$100</span>
                        <span class="text-success fw-bold fs-5">$@ViewBag.Price</span>
                    </div>

                    <form method="get" class="mt-3">
                        <select name="promoCode" class="form-select mb-3">
                            <option value="">-- Select promo code --</option>
                            @foreach (var code in promoCodes)
                            {
                                <option value="@code" selected="@(code == promoCode)">
                                    @code
                                </option>




                            }
                        </select>
                        <button type="submit" class="btn btn-primary w-100">Apply Code</button>
                    </form>

                    @if (promoCode == "WINTER25")
                    {
                        <p class="text-success mt-3">15% discount applied!</p>
                    }
                    else if (promoCode == "FREESHIP")
                    {
                        <p class="text-success mt-3">$5 discount applied!</p>
                    }
                    else if (promoCode == "CU25")
                    {
                        <p class="text-success mt-3">25% discount applied!</p>
                    }
                    else if (promoCode == "ABHAY")
                    {
                        <p class="text-success mt-3">$50 discount applied!</p>
                    }

                </div>
            </div>
        </div>
    </div>
</div>